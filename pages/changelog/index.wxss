.page {
  min-height: 100vh;
  padding: 32rpx 32rpx 56rpx;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hint {
  font-size: 26rpx;
  color: var(--text-tertiary, #888);
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.card {
  background-color: var(--background-secondary);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--card-shadow);
  border: 1rpx solid var(--border-color);
  box-sizing: border-box;
}

.card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.version {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.date {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.item:last-child {
  margin-bottom: 0;
}

.bullet {
  flex-shrink: 0;
  width: 28rpx;
  font-size: 28rpx;
  color: var(--primary-color);
  line-height: 1.55;
}

.line {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.55;
}

.empty {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--text-secondary);
  padding: 48rpx;
}
