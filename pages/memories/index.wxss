.page-wrapper {
  min-height: 100vh;
  background-color: var(--background-primary);
  padding-bottom: 60px;
}

.memories-container {
  position: relative;
  padding: 40rpx 0 60rpx;
}

/* в”Җв”Җв”Җ еҚЎзүҮж§ҪдҪҚпјҡW/4 е®ҪпјҢдёӯеҝғиҗҪеңЁ W/4 е’Ң 3W/4 в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

.slot {
  position: relative;
  z-index: 1;
  width: 33.33%;
  margin-bottom: 100rpx;
}

/* е·ҰеҚЎзүҮпјҡе·Ұиҫ№и·қ 8.33%пјҢдҪҝеҚЎзүҮдёӯеҝғиҗҪеңЁ W/4 */
.slot-left {
  margin-left: 8.33%;
  margin-right: auto;
}

/* еҸіеҚЎзүҮпјҡеҸіиҫ№и·қ 8.33%пјҢдҪҝеҚЎзүҮдёӯеҝғиҗҪеңЁ 3W/4 */
.slot-right {
  margin-left: auto;
  margin-right: 8.33%;
}

/* в”Җв”Җв”Җ еҚЎзүҮпјҲз»ҹдёҖз»“жһ„пјү в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

.card {
  width: 100%;
  border-radius: 12rpx;
  background-color: var(--background-secondary, #fff);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* в”Җв”Җв”Җ дёҠж–№пјҡжӯЈж–№еҪўеҢәеҹҹпјҲpadding-bottom: 100% ж–№жЎҲпјүв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

/* padding-bottom: 100% дҪҝй«ҳеәҰ = е®ҪеәҰпјҢеӯҗе…ғзҙ з»қеҜ№е®ҡдҪҚеЎ«ж»Ў */
.card-upper {
  width: 100%;
  padding-bottom: 100%;
  position: relative;
  flex-shrink: 0;
  overflow: hidden;
}

/* еӣҫзүҮе’Ң + жҢүй’®йғҪз»қеҜ№е®ҡдҪҚпјҢеЎ«ж»ЎжӯЈж–№еҪў */
.card-image-wrap,
.add-image-btn {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.card-image {
  width: 100%;
  height: 100%;
  display: block;
}

.card-image-more {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 16rpx;
  font-weight: 600;
  line-height: 1.4;
}

/* + жҢүй’®пјҡз»қеҜ№е®ҡдҪҚеҗҺз”Ё flex еұ…дёӯеӣҫж Ү */
.add-image-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--background-secondary, #f5f5f7);
}

.add-icon-img {
  width: 40px;
  height: 40px;
}

/* в”Җв”Җв”Җ дёӢж–№пјҡеӣәе®ҡдёӨиЎҢж–Үеӯ—еҢәеҹҹ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

/* й«ҳеәҰ = 22rpx Г— 1.5 Г— 2иЎҢ + 10rpxдёҠ + 12rpxдёӢ padding = 88rpx */
.card-textarea {
  width: 100%;
  font-size: 22rpx;
  color: var(--text-primary);
  line-height: 1.5;
  height: 88rpx;
  box-sizing: border-box;
  background: transparent;
  padding: 10rpx 12rpx 12rpx;
  text-align: center;
  overflow: hidden;
}

.card-textarea-placeholder {
  color: var(--text-tertiary, #ccc);
  font-size: 22rpx;
  text-align: center;
}

/* в”Җв”Җв”Җ ж—Ҙжңҹж ҮзӯҫеұӮ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

.date-label {
  position: absolute;
  display: flex;
  align-items: center;
  width: 25%;
  transform: translateY(-50%);
  z-index: 2;
}

/* е·Ұдҫ§еҚЎзүҮпјҡж ҮзӯҫеңЁеҸідҫ§пјҲW/2 еҲ° 3W/4пјүпјҢеҶ…е®№йқ еҸіпјҢзӮ№еңЁжңҖеҸі */
.date-label-right {
  left: 50%;
  justify-content: flex-end;
}

/* еҸідҫ§еҚЎзүҮпјҡж ҮзӯҫеңЁе·Ұдҫ§пјҲW/4 еҲ° W/2пјүпјҢеҶ…е®№йқ е·ҰпјҢзӮ№еңЁжңҖе·Ұ */
.date-label-left {
  left: 25%;
  justify-content: flex-start;
}

.date-picker-wrap {
  display: block;
}

.date-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 0.8;
  }

  50% {
    transform: scale(1.8);
    opacity: 0.2;
  }

  100% {
    transform: scale(1);
    opacity: 0.8;
  }
}

.date-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.3);
  flex-shrink: 0;
  animation: pulse 2.4s ease-in-out infinite;
}

.date-text {
  font-size: 14px;
  color: var(--text-secondary, #888);
  white-space: nowrap;
}

.date-text-placeholder {
  color: var(--text-tertiary, #ccc);
}

.date-delete {
  width: 24px;
  height: 24px;
  flex-shrink: 0;
}

/* в”Җв”Җв”Җ е…ЁеұҸеӣҫзүҮйў„и§Ҳ Overlay в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ */

.image-viewer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.92);
  z-index: 9999;
  display: flex;
  flex-direction: column;
}

/* йЎ¶йғЁпјҡд»…йЎөз ҒпјҢеұ…дёӯжҳҫзӨә */
.viewer-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 32rpx 20rpx;
  flex-shrink: 0;
}

.viewer-counter {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

/* еӣҫзүҮдё»дҪ“ swiper */
.viewer-swiper {
  flex: 1;
  width: 100%;
}

.viewer-swiper-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.viewer-image {
  width: 100%;
  height: 100%;
}

/* еә•йғЁж“ҚдҪңж Ҹпјҡеӣәе®ҡй«ҳеәҰ 80pxпјҢиҙҙеә•жҳҫзӨә */
.viewer-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  height: 80px;
  flex-shrink: 0;
}

.viewer-btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.viewer-btn-delete {
  background-color: rgba(255, 59, 48, 0.2);
  color: #ff3b30;
  border: 1rpx solid rgba(255, 59, 48, 0.4);
}

.viewer-btn-add {
  background-color: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}