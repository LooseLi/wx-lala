.page-wrapper {
  min-height: 100vh;
  background-color: var(--background-primary);
  padding-bottom: 60px;
}

.memories-container {
  position: relative;
  padding: 40rpx 0 60rpx;
}

/* ─── 卡片槽位：W/4 宽，中心落在 W/4 和 3W/4 ───────────────────── */

.slot {
  position: relative;
  z-index: 2;
  width: 33.33%;
  margin-bottom: 100rpx;
}

/* 左卡片：左边距 8.33%，使卡片中心落在 W/4 */
.slot-left {
  margin-left: 8.33%;
  margin-right: auto;
}

/* 右卡片：右边距 8.33%，使卡片中心落在 3W/4 */
.slot-right {
  margin-left: auto;
  margin-right: 8.33%;
}

/* ─── 卡片（统一结构） ──────────────────────────────────────────── */

.card {
  width: 100%;
  border-radius: 12rpx;
  background-color: var(--background-secondary, #fff);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* ─── 上方：正方形区域（padding-bottom: 100% 方案）────────────── */

/* padding-bottom: 100% 使高度 = 宽度，子元素绝对定位填满 */
.card-upper {
  width: 100%;
  padding-bottom: 100%;
  position: relative;
  flex-shrink: 0;
  overflow: hidden;
}

/* 图片和 + 按钮都绝对定位，填满正方形 */
.card-image-wrap,
.add-image-btn {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.card-image {
  width: 100%;
  height: 100%;
  display: block;
}

.card-image-more {
  position: absolute;
  bottom: 6rpx;
  right: 6rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 18rpx;
  padding: 2rpx 8rpx;
  border-radius: 16rpx;
  font-weight: 600;
  line-height: 1.4;
}

/* + 按钮：绝对定位后用 flex 居中图标 */
.add-image-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--background-secondary, #f5f5f7);
}

.add-icon-body {
  animation: charmPopIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  transform-origin: center center;
}

.add-icon-img {
  width: 64px;
  height: 64px;
  display: block;
}

.add-icon-img.icon-tap,
.card-charm-icon.icon-tap {
  animation: iconTapScale 0.28s ease;
}

/* ─── 下方：固定两行文字区域 ────────────────────────────────────── */

/* 高度 = 22rpx × 1.5 × 2行 + 10rpx上 + 12rpx下 padding = 88rpx */
.card-textarea {
  width: 100%;
  font-size: 22rpx;
  color: var(--text-primary);
  line-height: 1.5;
  height: 88rpx;
  box-sizing: border-box;
  background: transparent;
  padding: 10rpx 12rpx 12rpx;
  text-align: center;
  overflow: hidden;
}

.card-textarea-placeholder {
  color: var(--text-tertiary, #ccc);
  font-size: 22rpx;
  text-align: center;
}

/* ─── 删除挂件：绳子层 z-index 1，图标层 z-index 3 ─────────────── */

.card-charm-rope-layer {
  position: absolute;
  z-index: 1;
  pointer-events: none;
}

.card-charm-rope {
  width: 2px;
  background-color: rgba(232, 160, 69, 0.55);
  flex-shrink: 0;
}

.card-charm-icon-wrap {
  position: absolute;
  z-index: 3;
}

.card-charm-body {
  animation: charmPopIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  transform-origin: top center;
}

.card-charm-icon {
  width: 25px;
  height: 25px;
  flex-shrink: 0;
  display: block;
  animation: charmSway 3s ease-in-out 0.4s infinite;
}


@keyframes charmPopIn {
  0% {
    transform: scale(0);
    opacity: 0;
  }

  80% {
    transform: scale(1.1);
    opacity: 1;
  }

  100% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes charmSway {

  0%,
  100% {
    transform: translateY(0);
  }

  50% {
    transform: translateY(4rpx);
  }
}

@keyframes iconTapScale {
  0% {
    transform: scale(1);
  }

  45% {
    transform: scale(0.78);
  }

  100% {
    transform: scale(1);
  }
}

@media (prefers-color-scheme: dark) {
  .card-charm-icon {
    filter: invert(1);
  }

  .card-charm-rope {
    background-color: rgba(232, 160, 69, 0.75);
  }
}

/* ─── 日期标签层 ────────────────────────────────────────────────── */

.date-label {
  position: absolute;
  display: flex;
  align-items: center;
  width: 25%;
  transform: translateY(-50%);
  z-index: 2;
}

/* 左侧卡片：标签在右侧（W/2 到 3W/4），内容靠右，点在最右 */
.date-label-right {
  left: 50%;
  justify-content: flex-end;
}

/* 右侧卡片：标签在左侧（W/4 到 W/2），内容靠左，点在最左 */
.date-label-left {
  left: 25%;
  justify-content: flex-start;
}

.date-picker-wrap {
  display: block;
}

.date-inner {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

@keyframes pulse {
  0% {
    transform: scale(1);
    opacity: 0.8;
  }

  50% {
    transform: scale(1.8);
    opacity: 0.2;
  }

  100% {
    transform: scale(1);
    opacity: 0.8;
  }
}

.date-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: #E8A045;
  box-shadow: 0 0 0 2px rgba(232, 160, 69, 0.3);
  flex-shrink: 0;
  animation: pulse 2.4s ease-in-out infinite;
}

.date-text {
  font-size: 14px;
  color: var(--text-secondary, #888);
  white-space: nowrap;
}

.date-text-placeholder {
  color: var(--text-tertiary, #ccc);
}

/* ─── 全屏图片预览 Overlay ──────────────────────────────────────── */

.image-viewer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.92);
  z-index: 9999;
  display: flex;
  flex-direction: column;
}

/* 顶部：仅页码，居中显示 */
.viewer-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 32rpx 20rpx;
  flex-shrink: 0;
}

.viewer-counter {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

/* 图片主体 swiper */
.viewer-swiper {
  flex: 1;
  width: 100%;
}

.viewer-swiper-item {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.viewer-image {
  width: 100%;
  height: 100%;
}

/* 底部操作栏：固定高度 80px，贴底显示 */
.viewer-footer {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 32rpx;
  height: 80px;
  flex-shrink: 0;
}

.viewer-btn {
  padding: 16rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.viewer-btn-delete {
  background-color: rgba(255, 59, 48, 0.2);
  color: #ff3b30;
  border: 1rpx solid rgba(255, 59, 48, 0.4);
}

.viewer-btn-add {
  background-color: rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}