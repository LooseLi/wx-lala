<wxs module="cmap">
  function c(v) {
    if (v <= 0) {
      return 'c0'
    }
    if (v > 2048) {
      return 'cbig'
    }
    return 'c' + v
  }
  module.exports.c = c
</wxs>

<view class="g2048-page">
  <view class="g2048-center-wrap">
    <view class="g2048-content">
      <view class="toolbar">
        <view class="stat-box">
          <text class="stat-label">本局得分</text>
          <text class="stat-value">{{score}}</text>
        </view>
        <view class="stat-box stat-box--best">
          <text class="stat-label">最高记录</text>
          <text class="stat-value">{{best}}</text>
        </view>
        <view class="btn-new" hover-class="btn-new--press" bindtap="onNewGame">新游戏</view>
      </view>

      <view class="board-outer" catchtouchmove="catchMove" bindtouchstart="touchStart" bindtouchend="touchEnd">
        <view class="board">
          <view class="board-bg">
            <view class="row" wx:for="{{rowIdx}}" wx:for-item="ri" wx:key="*this">
              <view class="cell" wx:for="{{rowIdx}}" wx:for-item="ci" wx:key="*this" />
            </view>
          </view>
          <view id="g2048-tile-layer" class="tile-layer">
            <view wx:for="{{tiles}}" wx:key="id" class="tile-abs tile-anim {{cmap.c(item.v)}}{{item.isSpawn ? ' tile--spawn' : ''}}" style="left: {{item.l}}rpx; top: {{item.tp}}rpx; width: {{item.w}}rpx; height: {{item.h}}rpx;">
              <text class="tile-text">{{item.v}}</text>
            </view>
          </view>
        </view>
      </view>

      <text class="hint">上下左右滑动操作</text>
    </view>
  </view>

  <view class="mask" wx:if="{{showWinMask && !gameOver}}">
    <view class="win-victory-anchor">
      <view class="win-lottie-wrap">
        <canvas type="2d" id="g2048-win-lottie" class="win-lottie-canvas"></canvas>
      </view>
      <view class="mask-card">
        <text class="mask-title">达成 2048！</text>
        <text class="mask-sub">好厉害，要挑战更高分吗？</text>
        <view class="mask-btns">
          <view class="mask-btn mask-btn--primary" hover-class="mask-btn--press" bindtap="onContinueAfterWin">继续</view>
        </view>
      </view>
    </view>
  </view>

  <view class="mask" wx:if="{{gameOver}}">
    <view class="mask-card">
      <text class="mask-title">游戏结束</text>
      <text class="mask-sub">本局得分 {{score}}</text>
      <text class="mask-strategy-tip" wx:if="{{!reviveFreeUsed}}">尽量把大数锁在角落喔～</text>
      <text class="mask-revive-hint" wx:if="{{reviveFreeUsed}}">当前积分 {{currentPoints}} · 每次复活消耗 10 积分</text>
      <view class="mask-btns mask-btns--col">
        <view class="mask-btn mask-btn--primary" hover-class="mask-btn--press" bindtap="onRevive">{{reviveFreeUsed ? '10 积分复活' : '免费复活'}}</view>
        <view class="mask-btn mask-btn--secondary" hover-class="mask-btn--press" bindtap="onRetry">再玩一局</view>
      </view>
    </view>
  </view>
</view>