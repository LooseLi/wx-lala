/* 布局：整页为列；主内容在可视区内垂直居中；得分-棋盘 60rpx、棋盘-提示 30rpx */
.g2048-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx 32rpx calc(32rpx + constant(safe-area-inset-bottom));
  padding: 24rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
  background: #faf8ef;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

/* 占满除 fixed 弹层外的区域，将整块（得分+棋盘+提示）在垂直方向居中 */
.g2048-center-wrap {
  flex: 1;
  width: 100%;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

/* 得分、棋盘、提示的竖直排布：得分-棋盘 60rpx，棋盘-提示 30rpx */
.g2048-content {
  width: 100%;
  max-width: 700rpx;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.toolbar {
  width: 100%;
  margin-bottom: 60rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.stat-box {
  background: #bbada0;
  border-radius: 8rpx;
  padding: 12rpx 24rpx;
  min-width: 120rpx;
  text-align: center;
}

.stat-box--best {
  background: #8f7a66;
}

.stat-label {
  display: block;
  font-size: 20rpx;
  color: #eee4d4;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.btn-new {
  background: #8f7a66;
  color: #f9f6f2;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 28rpx;
  border-radius: 8rpx;
}

.btn-new--press {
  opacity: 0.88;
  transform: scale(0.98);
}

/* 棋盘 */
.board-outer {
  width: 100%;
  max-width: 700rpx;
  margin-bottom: 30rpx;
  touch-action: none;
  flex-shrink: 0;
}

.board {
  position: relative;
  width: 100%;
  aspect-ratio: 1;
  max-height: 88vw;
  background: #bbada0;
  border-radius: 12rpx;
  padding: 12rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.board-bg {
  position: relative;
  z-index: 0;
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 12rpx;
  min-height: 0;
}

.row {
  flex: 1;
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  min-height: 0;
}

.cell {
  flex: 1;
  background: rgba(238, 228, 218, 0.35);
  border-radius: 6rpx;
  min-width: 0;
  min-height: 0;
}

/* 与格线对齐的滑块层：同 id 的块 left/top 变化带过渡，形成滑动 */
.tile-layer {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 12rpx;
  bottom: 12rpx;
  z-index: 1;
  pointer-events: none;
}

.tile-abs {
  position: absolute;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  /* 与底格等宽满格对位，不额外内边距，避免与 flex 格错位 */
  padding: 0;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.1);
  transition:
    left 0.16s ease,
    top 0.16s ease;
  will-change: left, top;
}

.tile-anim {
  -webkit-backface-visibility: hidden;
  backface-visibility: hidden;
}

/* 新落子 */
.tile--spawn {
  animation: tilePop 0.2s ease-out;
}

@keyframes tilePop {
  0% {
    transform: scale(0.65);
    opacity: 0.8;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.tile-text {
  font-weight: 700;
  color: #776e65;
  font-size: 40rpx;
  line-height: 1;
}

.c2 {
  background: #eee4da;
}
.c2 .tile-text {
  color: #776e65;
  font-size: 44rpx;
}

.c4 {
  background: #ede0c8;
}
.c4 .tile-text {
  color: #776e65;
  font-size: 44rpx;
}

.c8,
.c16,
.c32,
.c64 {
  color: #f9f6f2;
}
.c8 {
  background: #f2b179;
}
.c8 .tile-text,
.c16 .tile-text,
.c32 .tile-text,
.c64 .tile-text {
  color: #f9f6f2;
  font-size: 44rpx;
}

.c16 {
  background: #f59563;
}
.c32 {
  background: #f67c5f;
}
.c64 {
  background: #f65e3b;
}

.c128,
.c256,
.c512 {
  background: #edcf72;
  box-shadow: 0 0 20rpx rgba(243, 215, 116, 0.5);
}
.c128 .tile-text,
.c256 .tile-text,
.c512 .tile-text {
  color: #f9f6f2;
  font-size: 40rpx;
}

.c256 {
  background: #edcc61;
}
.c512 {
  background: #edc850;
}

.c1024,
.c2048 {
  background: #edc53f;
  box-shadow: 0 0 24rpx rgba(243, 215, 116, 0.7);
}
.c1024 .tile-text,
.c2048 .tile-text {
  color: #f9f6f2;
  font-size: 34rpx;
}

.c2048 {
  background: #edc22e;
}

.cbig {
  background: #3c3a32;
  box-shadow: 0 0 16rpx rgba(0, 0, 0, 0.2);
}
.cbig .tile-text {
  color: #f9f6f2;
  font-size: 30rpx;
}

.hint {
  text-align: center;
  font-size: 24rpx;
  color: #776e65;
  opacity: 0.9;
}

/* 弹层 */
.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  box-sizing: border-box;
}

.mask-card {
  background: #faf8ef;
  border-radius: 16rpx;
  padding: 48rpx 40rpx;
  max-width: 560rpx;
  width: 100%;
  text-align: center;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.12);
  border: 2rpx solid #bbada0;
}

/* 胜利层：仅弹窗参与垂直居中；Lottie 绝对叠在弹窗正上方、同宽、底边贴弹窗顶 */
.win-victory-anchor {
  position: relative;
  width: 100%;
  max-width: 560rpx;
  box-sizing: border-box;
  /* 布局高度=仅 .mask-card，由 .mask 的 flex 把弹窗置于视口垂直居中 */
}

.win-victory-anchor .win-lottie-wrap {
  position: absolute;
  left: 0;
  right: 0;
  width: 100%;
  /* 动效区加大，约等于原 240rpx 的 1.5～1.6 倍 */
  height: 400rpx;
  bottom: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  pointer-events: none;
}

.win-lottie-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.mask-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #776e65;
  margin-bottom: 16rpx;
}

.mask-sub {
  display: block;
  font-size: 28rpx;
  color: #8f7a66;
  margin-bottom: 40rpx;
  line-height: 1.5;
}

.mask-btns {
  display: flex;
  flex-direction: row;
  justify-content: center;
}

.mask-btn {
  min-width: 200rpx;
  padding: 20rpx 32rpx;
  border-radius: 8rpx;
  background: #8f7a66;
  color: #f9f6f2;
  font-size: 30rpx;
  font-weight: 600;
}

.mask-btn--primary {
  background: #6c5ce7;
  color: #fff;
}

.mask-btn--press {
  opacity: 0.9;
  transform: scale(0.98);
}

.c0 {
  display: none;
}
