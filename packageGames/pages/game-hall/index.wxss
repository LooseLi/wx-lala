.hall-scroll {
  height: 100vh;
  background: linear-gradient(165deg, #fff4e8 0%, #f3e8ff 45%, #e8f4ff 100%);
  box-sizing: border-box;
}

.hall-page {
  padding: 24rpx 28rpx 48rpx;
  box-sizing: border-box;
}

.card-raise {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 12rpx 40rpx rgba(120, 90, 200, 0.12);
}

/* 顶栏 */
.top-bar {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 32rpx;
  margin-bottom: 56rpx;
}

.top-bar-left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.avatar {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  border: 4rpx solid #fff;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  flex-shrink: 0;
}

.top-bar-user {
  margin-left: 16rpx;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.top-bar-nickname {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3436;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.25;
}

/* 设计 4px 间距：按 375 宽 2x 约 8rpx */
.top-bar-welcome {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #636e72;
  line-height: 1.3;
}

.top-bar-right {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.stat-row {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: 16rpx;
}

.stat-pill {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
}

.stat-pill--pressed {
  opacity: 0.88;
  transform: scale(0.98);
}

.stat-coin {
  background: linear-gradient(135deg, #ffeaa7, #fdcb6e);
}

.stat-fire {
  background: linear-gradient(135deg, #ffecd2, #ff9a76);
}

.stat-emoji {
  margin-right: 8rpx;
  font-size: 30rpx;
}

.stat-num {
  font-weight: 700;
  color: #2d3436;
  min-width: 48rpx;
}

.stat-label {
  margin-left: 8rpx;
  font-size: 22rpx;
  color: #636e72;
}

.hint-text {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #d63031;
}

.section-head {
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.section-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #2d3436;
  margin-bottom: 8rpx;
  line-height: 1.25;
}

.section-sub {
  display: block;
  font-size: 24rpx;
  color: #636e72;
  line-height: 1.4;
}

/* 游戏列表：单行单列，一行一张 */
.game-list {
  display: flex;
  flex-direction: column;
  gap: 36rpx;
  margin-bottom: 56rpx;
}

.game-card {
  width: 100%;
  border-radius: 32rpx;
  overflow: hidden;
  min-height: 280rpx;
  position: relative;
  box-sizing: border-box;
}

.game-card--active {
  box-shadow: 0 20rpx 40rpx rgba(232, 67, 147, 0.35);
}

.game-card--hover {
  transform: scale(0.98);
  opacity: 0.96;
}

.game-card--disabled {
  opacity: 0.85;
  box-shadow: 0 12rpx 28rpx rgba(0, 0, 0, 0.08);
}

.game-card-bg {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 0;
}

/* 粉红渐变 + 与稿图接近的明度变化 */
.game-card-bg--2048 {
  background: linear-gradient(145deg, #ff6b9d 0%, #fd4d8a 45%, #e84393 100%);
}

.game-card-bg--klotski {
  background: linear-gradient(145deg, #9aa5b1 0%, #6c7a89 100%);
}

/* 右侧大圆装饰 */
.game-card-decor {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 0;
  pointer-events: none;
  overflow: hidden;
}

.game-card-decor--2048 .game-card-bubble:nth-child(1) {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  right: -32rpx;
  top: -40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.game-card-decor--2048 .game-card-bubble:nth-child(2) {
  position: absolute;
  width: 280rpx;
  height: 280rpx;
  right: -90rpx;
  bottom: -100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.game-card-decor--klotski .game-card-bubble:nth-child(1) {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  right: -32rpx;
  top: -40rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.game-card-decor--klotski .game-card-bubble:nth-child(2) {
  position: absolute;
  width: 280rpx;
  height: 280rpx;
  right: -90rpx;
  bottom: -100rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.08);
}

.game-card-body {
  position: relative;
  z-index: 1;
  padding: 42rpx 32rpx 42rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-height: 280rpx;
  box-sizing: border-box;
}

/* 图标本体：轻玻璃感圆角底 */
.game-card-icon-wrap {
  width: 90rpx;
  height: 90rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.38);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 34rpx;
  flex-shrink: 0;
}

.game-card-icon-wrap--muted {
  background: rgba(255, 255, 255, 0.22);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
}

.game-card-icon {
  width: 56rpx;
  height: 56rpx;
  display: block;
  flex-shrink: 0;
}

.game-card--active .game-card-icon,
.game-card--disabled .game-card-icon {
  filter: brightness(0) invert(1);
  opacity: 0.96;
}

.game-name {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  line-height: 1.2;
  letter-spacing: 0.5rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.15);
}

.game-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.95);
  margin-top: 4rpx;
  margin-bottom: 24rpx;
  line-height: 1.45;
  font-weight: 400;
}

/* 主按钮：白底 + 深字 + 三角 + 浮起感 */
.play-btn {
  text-align: center;
  margin-top: auto;
  align-self: stretch;
  min-height: 64rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 999rpx;
  border: none;
  box-sizing: border-box;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
}

.play-btn::after {
  border: none;
}

.play-btn--solid {
  color: #2d3436;
  background: #fff;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.12);
  padding-top: 2rpx;
  padding-bottom: 2rpx;
}

/* 与稿一致：24×24，与文案间距 12（rpx） */
.play-btn-start-icon {
  width: 24rpx;
  height: 24rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
  display: block;
}

.play-btn--hover {
  opacity: 0.92;
  transform: scale(0.99);
}

.game-card--disabled .game-name,
.game-card--disabled .game-sub {
  color: #fff;
  text-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.2);
}

.play-btn--ghost {
  line-height: 64rpx;
  background: rgba(255, 255, 255, 0.32);
  color: #fff;
  box-shadow: none;
  display: block;
}

/* 商城 */
.shop-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 32rpx 28rpx;
}

.shop-card--hover {
  opacity: 0.92;
  transform: scale(0.99);
}

.shop-icon-wrap {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.shop-texts {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.shop-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2d3436;
}

.shop-desc {
  font-size: 24rpx;
  color: #74b9ff;
}

.shop-arrow {
  font-size: 48rpx;
  color: #b2bec3;
  font-weight: 300;
}

.safe-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  min-height: 24rpx;
}
